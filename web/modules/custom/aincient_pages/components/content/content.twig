{% set tone_class = {
  default: 'bg-background text-foreground',
  muted: 'bg-muted text-muted-foreground',
  brand: 'bg-primary text-primary-foreground',
  inverted: 'bg-foreground text-background',
}[tone|default('default')] %}
{% set on_dark = tone in ['brand', 'inverted'] %}
{% set has_image = variant != 'text-only' and image %}

<section class="{{ tone_class }}">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:py-24">
    <div class="grid items-center gap-12 lg:gap-16 {{ has_image ? 'lg:grid-cols-2' : '' }}">
      <div class="{{ has_image and variant == 'image-left' ? 'lg:order-2' : '' }} {{ not has_image ? 'mx-auto max-w-3xl text-center' : '' }}">
        {% if eyebrow %}<p class="text-sm font-semibold uppercase tracking-wider {{ on_dark ? 'opacity-90' : 'text-muted-foreground' }}">{{ eyebrow }}</p>{% endif %}
        {% if heading %}<h2 class="mt-3 font-display text-3xl sm:text-4xl [font-weight:var(--heading-weight)] tracking-tight">{{ heading }}</h2>{% endif %}
        {% if subheading %}<p class="mt-4 text-lg opacity-70">{{ subheading|inline_md }}</p>{% endif %}
        {% if body %}<div class="mt-5 text-base leading-relaxed opacity-80">{{ body|inline_md(true) }}</div>{% endif %}
        {% if cta_label %}
          <div class="mt-8 {{ not has_image ? 'flex justify-center' : '' }}">
            <a href="{{ cta_url|default('#') }}" class="inline-flex items-center rounded-[var(--button-radius)] px-6 py-3 text-sm [font-weight:var(--button-weight)] shadow-[var(--button-shadow)] border-solid border-[length:var(--button-border-width)] border-[color:var(--button-border)] transition {{ on_dark ? 'bg-background text-foreground' : 'bg-primary text-primary-foreground' }} hover:opacity-90">{{ cta_label }}</a>
          </div>
        {% endif %}
      </div>
      {% if has_image %}
        <div class="{{ variant == 'image-left' ? 'lg:order-1' : '' }}">
          <div class="ain-img w-full rounded-[var(--card-radius)] overflow-hidden shadow-[var(--shadow-lg)] ring-1 ring-border aspect-[4/3]">{% block image %}{{ image }}{% endblock %}</div>
        </div>
      {% endif %}
    </div>
  </div>
</section>
