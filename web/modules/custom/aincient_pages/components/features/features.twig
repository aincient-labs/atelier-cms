{% set tone_class = {
  default: 'bg-background text-foreground',
  muted: 'bg-muted text-muted-foreground',
  brand: 'bg-primary text-primary-foreground',
  inverted: 'bg-foreground text-background',
}[tone|default('default')] %}
{% set cols = columns|default(3) == 2 ? 'md:grid-cols-2' : 'md:grid-cols-3' %}
{% set on_dark = tone in ['brand', 'inverted'] %}

<section class="{{ tone_class }}">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:py-24">
    {% if eyebrow or heading or subheading %}
      <div class="max-w-2xl mb-14">
        {% if eyebrow %}<p class="text-sm font-semibold uppercase tracking-wider {{ on_dark ? 'opacity-90' : 'text-muted-foreground' }}">{{ eyebrow }}</p>{% endif %}
        {% if heading %}<h2 class="mt-3 font-display text-3xl sm:text-4xl [font-weight:var(--features-heading-weight)] tracking-[var(--features-heading-tracking)]">{{ heading }}</h2>{% endif %}
        {% if subheading %}<p class="mt-4 text-lg opacity-70">{{ subheading|inline_md }}</p>{% endif %}
      </div>
    {% endif %}
    <div class="grid sm:grid-cols-2 {{ cols }} gap-6">
      {% for f in features %}
        <div class="rounded-[var(--card-radius)] border border-[color:var(--card-border)] {{ on_dark ? 'bg-background/5' : 'bg-card text-card-foreground' }} p-7 shadow-[var(--card-shadow)] transition hover:shadow-[var(--shadow-md)]">
          {% if f.icon %}<div class="flex h-11 w-11 items-center justify-center rounded-[var(--card-radius)] bg-primary/10 text-2xl">{{ f.icon }}</div>{% endif %}
          <h3 class="mt-5 font-display text-lg [font-weight:var(--features-title-weight)]">{{ f.title }}</h3>
          {% if f.body %}<p class="mt-2 text-sm leading-relaxed opacity-70">{{ f.body|inline_md }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>
