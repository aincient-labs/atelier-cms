{% set tone_class = {
  default: 'bg-background text-foreground',
  muted: 'bg-muted text-muted-foreground',
  brand: 'bg-primary text-primary-foreground',
  inverted: 'bg-foreground text-background',
}[tone|default('muted')] %}

<section class="{{ tone_class }}">
  <div class="mx-auto max-w-2xl px-6 py-16 text-center">
    {% if heading %}<h2 class="font-display text-3xl [font-weight:var(--heading-weight)] tracking-tight">{{ heading }}</h2>{% endif %}
    {% if subheading %}<p class="mt-3 text-lg opacity-70">{{ subheading|inline_md }}</p>{% endif %}
    <form class="mx-auto mt-7 flex max-w-md flex-col gap-3 sm:flex-row" onsubmit="return false">
      <label class="sr-only" for="newsletter-email">Email address</label>
      <input id="newsletter-email" type="email" placeholder="{{ placeholder|default('Enter your email') }}" class="w-full rounded-[var(--input-radius)] border border-border bg-background px-5 py-3 text-sm text-foreground outline-none transition focus-visible:ring-2 focus-visible:ring-[color:var(--focus-ring)]">
      <button type="submit" class="shrink-0 rounded-[var(--button-radius)] bg-primary px-6 py-3 text-sm [font-weight:var(--button-weight)] text-primary-foreground border-solid border-[length:var(--button-border-width)] border-[color:var(--button-border)] transition hover:opacity-90">{{ cta_label|default('Subscribe') }}</button>
    </form>
  </div>
</section>
