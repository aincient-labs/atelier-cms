{% set bare = variant|default('default') == 'bare' %}
{% set tone_class = {
  default: 'bg-background text-foreground',
  muted: 'bg-muted text-muted-foreground',
  brand: 'bg-primary text-primary-foreground',
  inverted: 'bg-foreground text-background',
}[tone|default('default')] %}

{# `bare` (set by the renderer for nested blocks, e.g. an accordion panel) drops
   the section band + outer padding so the parent owns the surface and spacing.
   The figure markup — and the `image` slot — is identical in both modes. #}
{% if not bare %}<section class="{{ tone_class }}"><div class="mx-auto max-w-5xl px-6 py-20 lg:py-24">{% endif %}
  <figure class="mx-auto">
    {# image is a Rift responsive <picture> render array supplied by the
       renderer from the `image` media token (an empty box when none is set
       yet, so the placed section is visible in the studio preview). Alt
       rides inside the picture; the caption is decorative copy below. #}
    <div class="ain-img flex aspect-[4/3] w-full items-center justify-center overflow-hidden rounded-[var(--card-radius)] bg-muted text-muted-foreground shadow-[var(--shadow-lg)] ring-1 ring-border">{% block image %}{{ image }}{% endblock %}</div>
    {% if caption %}<figcaption class="mt-3 text-center text-sm opacity-70">{{ caption|inline_md }}</figcaption>{% endif %}
  </figure>
{% if not bare %}</div></section>{% endif %}
