{% set tone_class = {
  default: 'bg-background text-foreground',
  muted: 'bg-muted text-muted-foreground',
  brand: 'bg-primary text-primary-foreground',
  inverted: 'bg-foreground text-background',
}[tone|default('brand')] %}
{% set on_dark = tone in ['brand', 'inverted'] %}

<section class="{{ tone_class }}">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center">
    {% if eyebrow %}<p class="text-sm font-semibold uppercase tracking-wider opacity-70">{{ eyebrow }}</p>{% endif %}
    {% if heading %}<p class="mt-3 font-display text-2xl [font-weight:var(--heading-weight)] tracking-tight text-balance sm:text-3xl">{{ heading }}</p>{% endif %}
    {% if subheading %}<p class="mt-3 text-lg opacity-80">{{ subheading|inline_md }}</p>{% endif %}
    {% if cta_label %}
      <div class="mt-7">
        <a href="{{ cta_url|default('#') }}" class="inline-flex items-center rounded-[var(--button-radius)] px-7 py-3 text-sm [font-weight:var(--button-weight)] shadow-[var(--button-shadow)] border-solid border-[length:var(--button-border-width)] border-[color:var(--button-border)] transition {{ on_dark ? 'bg-background text-foreground' : 'bg-primary text-primary-foreground' }} hover:opacity-90">{{ cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>
