{% set tone_class = {
  default: 'bg-background text-foreground',
  muted: 'bg-muted text-muted-foreground',
  brand: 'bg-primary text-primary-foreground',
  inverted: 'bg-foreground text-background',
}[tone|default('default')] %}
{% set on_dark = tone in ['brand', 'inverted'] %}
{% set count = tiers|length %}
{% set cols = count >= 3 ? 'lg:grid-cols-3' : (count == 2 ? 'sm:grid-cols-2' : '') %}

<section class="{{ tone_class }}">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:py-24">
    {% if eyebrow or heading or subheading %}
      <div class="mx-auto mb-14 max-w-2xl text-center">
        {% if eyebrow %}<p class="text-sm font-semibold uppercase tracking-wider {{ on_dark ? 'opacity-90' : 'text-muted-foreground' }}">{{ eyebrow }}</p>{% endif %}
        {% if heading %}<h2 class="mt-3 font-display text-3xl sm:text-4xl [font-weight:var(--heading-weight)] tracking-tight">{{ heading }}</h2>{% endif %}
        {% if subheading %}<p class="mt-4 text-lg opacity-70">{{ subheading|inline_md }}</p>{% endif %}
      </div>
    {% endif %}
    <div class="mx-auto grid max-w-5xl gap-8 {{ cols }}">
      {% for t in tiers %}
        <div class="flex flex-col rounded-[var(--card-radius)] border p-8 {{ t.featured ? 'border-primary ring-2 ring-primary shadow-[var(--shadow-lg)]' : 'border-[color:var(--card-border)]' }} {{ on_dark ? 'bg-background/5' : 'bg-card text-card-foreground' }}">
          {% if t.featured %}<p class="mb-2 inline-flex self-start rounded-[var(--button-radius)] bg-primary px-3 py-1 text-xs font-semibold text-primary-foreground">Most popular</p>{% endif %}
          <h3 class="font-display text-lg [font-weight:var(--subheading-weight)]">{{ t.name }}</h3>
          {% if t.description %}<p class="mt-1 text-sm opacity-70">{{ t.description|inline_md }}</p>{% endif %}
          <div class="mt-5 flex items-baseline gap-1">
            <span class="font-display text-4xl [font-weight:var(--display-weight)] tracking-tight">{{ t.price }}</span>
            {% if t.period %}<span class="text-sm opacity-60">/{{ t.period }}</span>{% endif %}
          </div>
          {% if t.features %}
            <ul class="mt-6 space-y-3 text-sm">
              {% for f in t.features %}
                <li class="flex gap-2"><span class="{{ on_dark ? '' : 'text-primary-on-surface' }}">&check;</span><span class="opacity-80">{{ f }}</span></li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if t.cta_label %}
            <a href="{{ t.cta_url|default('#') }}" class="mt-auto inline-flex items-center justify-center rounded-[var(--button-radius)] px-6 py-3 text-sm [font-weight:var(--button-weight)] transition {{ t.featured ? 'bg-primary text-primary-foreground' : (on_dark ? 'bg-background text-foreground' : 'border border-border') }} hover:opacity-90">{{ t.cta_label }}</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>
