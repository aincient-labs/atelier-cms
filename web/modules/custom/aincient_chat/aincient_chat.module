<?php

/**
 * @file
 * AIncient Chat module hooks.
 */

declare(strict_types=1);

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Markup;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;

/**
 * Implements hook_toolbar().
 *
 * Adds an "AIncient" tab to the admin toolbar so operators can jump back to
 * the console from any admin page (same pattern as FlowDrop's toolbar item).
 */
function aincient_chat_toolbar(): array {
  // The brand wordmark inlined into the tab: chip ring + lettering are
  // currentColor, so the SVG picks up the toolbar bar's (light) text colour —
  // one themable asset, no baked-in ink. Its aria-label gives the link its
  // accessible name ("AIncient"). The file is bundled with the module and
  // trusted, so the markup is safe to render verbatim.
  $module_path = \Drupal::service('extension.list.module')->getPath('aincient_chat');
  $wordmark = (string) @file_get_contents($module_path . '/images/aincient.svg');

  $items['aincient_chat'] = [
    '#type' => 'toolbar_item',
    // Right after "Back to site": the console is the product's home.
    '#weight' => -15,
    '#access' => \Drupal::currentUser()->hasPermission('use aincient operator console'),
    '#cache' => [
      'contexts' => ['user.permissions'],
    ],
    'tab' => [
      '#type' => 'link',
      '#title' => $wordmark !== '' ? Markup::create($wordmark) : t('AIncient'),
      '#url' => Url::fromRoute('aincient_chat.console'),
      '#attributes' => [
        'title' => t('Open the AIncient operator console'),
        'class' => ['toolbar-icon', 'toolbar-icon-aincient-console'],
      ],
    ],
    '#attached' => [
      'library' => ['aincient_chat/toolbar'],
    ],
  ];
  return $items;
}

/**
 * Implements hook_form_FORM_ID_alter() for user_login_form.
 *
 * After login, send the user straight to the AIncient operator console — the
 * chat-first experience is the product. (Power users can still navigate to
 * /admin manually.)
 */
function aincient_chat_form_user_login_form_alter(array &$form, FormStateInterface $form_state): void {
  $form['#submit'][] = 'aincient_chat_user_login_submit';
}

/**
 * Submit handler: redirect to the console after login.
 */
function aincient_chat_user_login_submit(array $form, FormStateInterface $form_state): void {
  // Respect an explicit ?destination= if present; otherwise go to the console.
  $request = \Drupal::request();
  if (!$request->query->has('destination')) {
    $form_state->setRedirect('aincient_chat.console');
  }
}

/**
 * Implements hook_theme_registry_alter().
 *
 * Repoints the Navigation sidebar layout template at our copy, so the sidebar
 * logo opens the AIncient console (the product's home) instead of the public
 * front page, and renders the AIncient chip mark. A no-op when the core
 * Navigation module is absent — the hook simply isn't registered.
 */
function aincient_chat_theme_registry_alter(array &$theme_registry): void {
  if (isset($theme_registry['navigation'])) {
    $theme_registry['navigation']['path'] = \Drupal::service('extension.list.module')
      ->getPath('aincient_chat') . '/templates';
  }
}

/**
 * Implements hook_preprocess_HOOK() for the navigation layout.
 *
 * Exposes the AIncient chip mark to our navigation template override. The chip
 * is the canonical brand asset (currentColor frame + brand bands); we inject a
 * fixed render size so it sits in the logo slot like the stock 40px logo.
 *
 * The chip is wrapped in an OPEN declarative shadow root so Gin's navigation
 * CSS cannot bleed in and repaint it. Gin assumes the sidebar logo is a generic
 * mark and ships high-specificity rules (it borrows an #id inside :is()) that
 * recolour `.admin-toolbar__logo svg rect|path` to its own theme palette. Once
 * the chip lives inside a shadow root those selectors no longer reach it, while
 * `color`/`currentColor` still inherits across the boundary so the frame keeps
 * tracking the sidebar text colour. The chip is fully self-contained (its own
 * defs/filter/style), which also keeps its filter id from colliding with the
 * light DOM. Declarative shadow DOM is activated by the HTML parser on the
 * server-rendered full page load, which is how the sidebar is delivered.
 */
function aincient_chat_preprocess_navigation(array &$variables): void {
  $module_path = \Drupal::service('extension.list.module')->getPath('aincient_chat');
  $chip = (string) @file_get_contents($module_path . '/images/aincient-chip.svg');
  if ($chip !== '') {
    // The source SVG sizes via viewBox only; pin a 40px footprint to match the
    // stock navigation logo and avoid a full-viewport render.
    $chip = preg_replace('/<svg /', '<svg width="40" height="40" ', $chip, 1);
    // Encapsulate in an open declarative shadow root to stop Gin's CSS bleed.
    $chip = '<span class="aincient-chip" style="display:inline-flex;line-height:0;color:#000">'
      . '<template shadowrootmode="open">' . $chip . '</template></span>';
    $variables['aincient_chip'] = Markup::create($chip);
  }
}

/**
 * Implements hook_page_bottom().
 *
 * Renders the live-site editor pill — the operator's way back INTO the console
 * from the public site (surface-switching Phase 3). It closes the dead-end the
 * public theme used to leave: the only recovery was the core Navigation sidebar
 * leaking through {{ page_top }}, which Phase 4 then retires.
 *
 * This THEMED path covers everything that renders through Drupal's page pipeline
 * — the front page, basic pages, listings — where the pill is the "Open Console"
 * fallback. AIncient pages (`aincient_page`) do NOT render here: their canonical
 * view is a bespoke chrome-less Response (aincient_pages PageSpikeController) and
 * gets the pill — deep-linked to the page — via hook_aincient_pages_shell_bottom()
 * below instead.
 *
 * Only on the LIVE SITE: skip the console's own routes (they render on the front
 * theme too) and anything not on the default/front theme (/admin runs the admin
 * theme, the login page its own). Both are deterministic per route, so a route
 * that never shows the pill simply never builds it. The element ALWAYS carries
 * `user.permissions` + `route` cache contexts (so the page varies correctly),
 * but the markup + its library attach ONLY for an operator: `#access` denial
 * would still bubble `#attached`, leaking the pill's CSS into a visitor's cached
 * page — so the permission gate lives in PHP, and a visitor's render is a bare
 * cacheability shell with no markup and no assets.
 */
function aincient_chat_page_bottom(array &$page): void {
  $route_name = (string) \Drupal::routeMatch()->getRouteName();
  if (str_starts_with($route_name, 'aincient_chat.')) {
    return;
  }
  $active_theme = \Drupal::theme()->getActiveTheme()->getName();
  if ($active_theme !== (string) \Drupal::config('system.theme')->get('default')) {
    return;
  }

  $build = ['#cache' => ['contexts' => ['user.permissions', 'route']]];
  if (\Drupal::currentUser()->hasPermission('use aincient operator console')) {
    // A themed page is never an AIncient page (those bypass the theme), so the
    // pill is always the console-home fallback here.
    $href = Url::fromRoute('aincient_chat.console')->toString();
    $build['#markup'] = _aincient_chat_editor_pill_anchor($href, (string) t('Open Console'));
    $build['#attached'] = ['library' => ['aincient_chat/editor-pill']];
  }
  $page['aincient_editor_pill'] = $build;
}

/**
 * Implements hook_aincient_pages_shell_bottom().
 *
 * The pill for an AIncient page's canonical view — the surface-switching win:
 * from the live page straight to editing it in the Content studio. The bespoke
 * page shell can't #attach a library, so the pill links its own CSS directly
 * (self-contained, per the hook contract). Operator-gated; a visitor gets
 * nothing — and since only authenticated operators bypass the anonymous page
 * cache, this per-user markup never leaks into a cached visitor page.
 */
function aincient_chat_aincient_pages_shell_bottom(NodeInterface $node): array {
  if (!\Drupal::currentUser()->hasPermission('use aincient operator console')) {
    return [];
  }
  // Route-name generated (never a hardcoded path): the Content-studio document
  // room for this node. Translation-aware — the source translation uses the
  // no-langcode route, a translation the langcode variant — matching the
  // console's URL codec (chat-ui/src/console-url.ts).
  $href = $node->isDefaultTranslation()
    ? Url::fromRoute('aincient_chat.console_doc', [
      'studio' => 'content',
      'doc_type' => 'node',
      'nid' => $node->id(),
    ])->toString()
    : Url::fromRoute('aincient_chat.console_doc_translation', [
      'studio' => 'content',
      'doc_type' => 'node',
      'nid' => $node->id(),
      'langcode' => $node->language()->getId(),
    ])->toString();
  $module_path = \Drupal::service('extension.list.module')->getPath('aincient_chat');
  $css = base_path() . $module_path . '/css/editor-pill.css?v=' . @filemtime($module_path . '/css/editor-pill.css');
  $link = '<link rel="stylesheet" href="' . htmlspecialchars($css, ENT_QUOTES) . '">';
  return [
    '#markup' => Markup::create($link . _aincient_chat_editor_pill_anchor($href, (string) t('Edit in Console'))),
  ];
}

/**
 * Build the editor-pill anchor markup (pencil icon + label). Shared by both the
 * themed page_bottom path and the bespoke-shell path so the pill is one artefact.
 * Same tab (surface-nav rule 3: output → workspace is switching modes on the
 * same object) — no target=_blank. Inputs are trusted (built here); the href is
 * generator-built and the label a static string, both escaped for safety.
 */
function _aincient_chat_editor_pill_anchor(string $href, string $label): Markup {
  // Lucide "pencil" — inline so the pill needs no icon font; coloured by the
  // library's currentColor.
  $icon = '<svg class="aincient-editor-pill__icon" viewBox="0 0 24 24" fill="none" '
    . 'stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" '
    . 'aria-hidden="true" focusable="false">'
    . '<path d="M12 20h9"/>'
    . '<path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/>'
    . '</svg>';
  return Markup::create(
    '<a class="aincient-editor-pill" href="' . htmlspecialchars($href, ENT_QUOTES) . '">'
    . $icon
    . '<span class="aincient-editor-pill__label">' . htmlspecialchars($label, ENT_QUOTES) . '</span>'
    . '</a>'
  );
}
