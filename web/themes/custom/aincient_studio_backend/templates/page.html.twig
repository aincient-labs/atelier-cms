{#
/**
 * @file
 * Studio Backend — the GitHub-settings layout: a fixed left sidebar (brand +
 * curated section nav + account) beside a scrolling main column.
 *
 * sb_nav / sb_home_url / sb_user are built in
 * aincient_studio_backend_preprocess_page().
 *
 * The brand mark is inlined (not <img>) so it inherits currentColor + the
 * --ain-* tokens: the frame themes to ink, the palette-knife swipe is the one
 * cinnabar pigment, and a second gesso swipe cuts an implied "A" through it
 * (the bold serif letter is retired — cms 628f498). Master: umbrella
 * docs/brand-assets/atelier/logo.svg (the console's <Chip> is the same paths).
 #}
<div class="sb-shell">
  <aside class="sb-sidebar">
    {# The aside paints the full-height column; this inner wrapper is the
       sticky, viewport-pinned part (see .sb-sidebar__inner). #}
    <div class="sb-sidebar__inner">
    <a href="{{ sb_home_url }}" class="sb-brand" title="{{ 'Administration home'|t }}">
      <span class="sb-brand__mark" aria-hidden="true">
        <svg viewBox="0 0 110.722 110.722" role="img" aria-label="AIncient">
          <g transform="translate(-82.020833,-82.020833)">
            <clipPath id="sb-mark-clip">
              <path transform="translate(14.194849,-18.623259)" d="m 137.58332,119.47935 -7.88927,20.60168 q 0.65456,0 1.8948,0.0344 3.89296,0.10336 5.30545,0.10336 1.72255,0 6.23563,-0.10336 0.99908,-0.0344 1.51584,-0.0344 z m -1.55029,-6.47679 h 5.92556 q 4.47863,13.67704 8.47494,24.97696 4.03077,11.29992 6.33898,16.98433 1.37804,3.27285 2.37712,4.03077 0.99908,0.75792 2.85943,0.75792 h 0.68902 v 2.41157 q -2.68717,-0.13781 -4.92649,-0.20671 -2.20486,-0.0689 -3.7207,-0.0689 -1.92926,0 -4.23747,0.0689 -2.30822,0.0689 -4.89204,0.20671 v -2.41157 h 0.65457 q 2.44602,0 3.34174,-0.55122 0.89573,-0.58566 0.89573,-2.10151 0,-0.55121 -0.13781,-1.20578 -0.1378,-0.68902 -0.44786,-1.6192 l -3.3762,-10.54199 q -1.30913,0 -3.5829,-0.0345 -4.13411,-0.10335 -5.30545,-0.10335 -2.34266,0 -4.44417,0.0344 -2.06706,0 -4.30638,0.0689 -2.44602,6.16673 -3.34174,8.99171 -0.89573,2.82498 -0.89573,4.03076 0,1.6881 0.89573,2.37712 0.89572,0.65457 3.20394,0.65457 h 0.93018 v 2.41157 q -2.51493,-0.13781 -4.71979,-0.20671 -2.17041,-0.0689 -3.89296,-0.0689 -1.37804,0 -3.4451,0.0689 -2.06705,0.0689 -4.47862,0.20671 v -2.37712 q 2.44602,-0.0689 3.85851,-0.96463 1.44694,-0.93017 2.51492,-3.06613 1.92925,-4.03077 6.82129,-16.12306 4.92649,-12.12675 10.36975,-26.63061 z" />
            </clipPath>
            <path fill="var(--ain-surface, #fbfaf7)" d="M 87.582977,87.582977 H 187.31909 V 187.31909 H 87.582977 Z" />
            <path fill="var(--ain-accent, #c2452a)" d="m 147.34886,87.685514 -59.76588,99.633596 40.07243,0.0598 59.6637,-99.795976 z" />
            <path fill="var(--ain-surface, #fbfaf7)" clip-path="url(#sb-mark-clip)" transform="translate(-14.194849,18.623259)" d="m 161.67599,69.164683 -59.76587,99.633577 40.07242,0.0598 59.6637,-99.795964 z" />
            <path fill="none" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" d="M 87.582977,87.582977 H 187.31909 V 187.31909 H 87.582977 Z" />
          </g>
        </svg>
      </span>
      <span class="sb-brand__label">Studio Backend</span>
    </a>

    {% if sb_console_url %}
      <a href="{{ sb_console_url }}" class="sb-console">
        <span class="sb-console__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 5.5 7 12l6.5 6.5"/><path d="M7 12h13"/></svg>
        </span>
        <span class="sb-console__label">{{ 'Console'|t }}</span>
      </a>
    {% endif %}

    <nav class="sb-nav" aria-label="{{ 'Backend sections'|t }}">
      {% for item in sb_nav %}
        <a href="{{ item.url }}" class="sb-nav__link{{ item.active ? ' is-active' }}"{{ item.active ? ' aria-current="page"' }}>
          <span class="sb-nav__icon" aria-hidden="true">
            {% if item.key == 'people' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><path d="M16 6.2a3 3 0 0 1 0 5.6"/><path d="M17.5 14.5a5.5 5.5 0 0 1 3 4.5"/></svg>
            {% elseif item.key == 'metering' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20V4"/><path d="M4 20h16"/><rect x="7" y="12" width="3" height="5"/><rect x="12" y="8" width="3" height="9"/><rect x="17" y="5" width="3" height="12"/></svg>
            {% elseif item.key == 'metering_settings' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h9"/><path d="M18 8h1"/><circle cx="16" cy="8" r="2"/><path d="M5 16h3"/><path d="M12 16h7"/><circle cx="10" cy="16" r="2"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 1 0 9 9h-9z"/><path d="M12 3v9"/><path d="M12 3a9 9 0 0 1 8.5 6"/></svg>
            {% endif %}
          </span>
          <span class="sb-nav__label">{{ item.label }}</span>
        </a>
      {% endfor %}
    </nav>

    {% if sb_user %}
      <div class="sb-account">
        <a href="{{ sb_user.url }}" class="sb-account__name">{{ sb_user.name }}</a>
        <a href="{{ sb_user.logout }}" class="sb-account__logout">{{ 'Sign out'|t }}</a>
      </div>
    {% endif %}
    </div>
  </aside>

  <main class="sb-main" role="main">
    <a id="main-content" tabindex="-1"></a>
    {% if page.highlighted %}
      <div class="sb-messages">{{ page.highlighted }}</div>
    {% endif %}
    <div class="sb-content">
      {{ page.content }}
    </div>
  </main>
</div>
