{#
/**
 * @file
 * Studio Backend override: core's markup with kit classes added — Stark's
 * default emits class-less <ul>s, so admin-kit.css's .tabs segmented row
 * (active = the cinnabar underline) could never match.
 */
#}
{% if primary %}
  <h2 class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
  <ul class="tabs">{{ primary }}</ul>
{% endif %}
{% if secondary %}
  <h2 class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
  <ul class="tabs tabs--secondary">{{ secondary }}</ul>
{% endif %}
