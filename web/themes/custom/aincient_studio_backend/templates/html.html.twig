{#
/**
 * @file
 * Studio Backend — document skeleton.
 *
 * Deliberately does NOT print {{ page_top }}: the Navigation/toolbar renders
 * there, and this theme replaces it with its own left sidebar (page.html.twig).
 * Omitting the region is the cleanest suppression — no markup, no nav.
 */
#}
<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token }}">
    <js-placeholder token="{{ placeholder_token }}">
  </head>
  <body{{ attributes }}>
    <a href="#main-content" class="sb-skip-link">{{ 'Skip to main content'|t }}</a>
    {{ page }}
    {{ page_bottom }}
    <js-bottom-placeholder token="{{ placeholder_token }}">
  </body>
</html>
