{#
/**
 * @file
 * AIncient front-end override of core's status-messages markup.
 *
 * The base (stark) template emits NO classes at all, so the theme's
 * `.messages` / `.messages--{type}` styling (build/input.css) never matched —
 * a failed-login error rendered as bare, un-themed text on the /user/login
 * auth screen. Re-add the stable `.messages` + `.messages--{type}` classes so
 * each message reads as its mood (error / warning / status).
 */
#}
{% for type, messages in message_list %}
  <div role="contentinfo" aria-label="{{ status_headings[type] }}"{{ attributes.addClass('messages', 'messages--' ~ type)|without('role', 'aria-label') }}>
    {% if type == 'error' %}
      <div role="alert">
    {% endif %}
    {% if status_headings[type] %}
      <h2 class="visually-hidden">{{ status_headings[type] }}</h2>
    {% endif %}
    {% if messages|length > 1 %}
      <ul>
        {% for message in messages %}
          <li>{{ message }}</li>
        {% endfor %}
      </ul>
    {% else %}
      {{ messages|first }}
    {% endif %}
    {% if type == 'error' %}
      </div>
    {% endif %}
  </div>
  {# Remove the classes so the next loop iteration starts clean. #}
  {% set attributes = attributes.removeClass('messages', 'messages--' ~ type) %}
{% endfor %}
