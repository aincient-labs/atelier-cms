# Copy to docker/.env and fill in. Never commit the real file.

# Required: a long random string for Drupal's hash salt.
#   generate: openssl rand -hex 32
HASH_SALT=

# No AI key here: the app boots keyless and you connect an AI provider in the
# console's first-run onboarding wizard (the key is stored inside Drupal, not
# in the environment).

# Optional overrides.
AINCIENT_IMAGE=ghcr.io/aincient-labs/atelier-cms:latest
DB_PASSWORD=aincient
# Leave ADMIN_PASS blank to have converge mint a random admin password on first
# boot (printed to the app log + private/INITIAL_ADMIN_PASSWORD). Set to pin your own.
ADMIN_PASS=
HTTP_PORT=41221   # "AINCI" in leet (4=A,1=I,2=N,2=C,1=I)

# Production: scope which Host headers Drupal answers to. Comma-separated PHP
# regex patterns. Unset = accept any host + a logged warning (fine for local
# evaluation, NOT for an internet-facing box).
#   AINCIENT_TRUSTED_HOSTS=^cms\.example\.com$,^www\.example\.com$
AINCIENT_TRUSTED_HOSTS=
