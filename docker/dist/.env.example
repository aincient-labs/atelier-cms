# Copy this file to `.env` (same folder) and fill it in. Never commit the real .env.

# ── Required ────────────────────────────────────────────────────────────────

# A long random string for Drupal's hash salt. Generate one with:
#   openssl rand -hex 32
HASH_SALT=

# No AI key here — the app boots keyless and prompts you to connect an AI
# provider in the console's first-run onboarding wizard. The key is stored
# inside Drupal (never in the environment or on disk as config).

# ── Optional ─────────────────────────────────────────────────────────────────

# Which image tag to run. :edge = latest build off main (rolling test image).
# Pin a specific build with e.g. :v0.1.0 once tagged releases exist.
AINCIENT_IMAGE=ghcr.io/aincient-labs/atelier:edge

# Database password (internal to the compose network).
DB_PASSWORD=aincient

# Leave blank to have a random admin password minted on first boot (printed to
# the app log + saved to the `private` volume at /INITIAL_ADMIN_PASSWORD).
# Set it to pin your own.
ADMIN_PASS=

# Host port the console is published on → http://localhost:<HTTP_PORT>/
HTTP_PORT=41221

# Only needed if you expose this beyond localhost. Comma-separated PHP regex
# patterns for the Host headers Drupal will answer to. Unset = accept any host
# (+ a logged warning) — acceptable for local evaluation, NOT for a public box.
#   AINCIENT_TRUSTED_HOSTS=^cms\.example\.com$
AINCIENT_TRUSTED_HOSTS=
